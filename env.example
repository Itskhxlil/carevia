# API (medical records)
API_PORT=3001

# Optional — omit MYSQL_* to use in-memory store for local demos
# MYSQL_HOST=127.0.0.1
# MYSQL_PORT=3306
# MYSQL_USER=root
# MYSQL_PASSWORD=
# MYSQL_DATABASE=carevia

# Production / custom API origin for Vite build (otherwise same-origin /api proxy in dev)
# VITE_API_BASE=https://your-api.example.com
